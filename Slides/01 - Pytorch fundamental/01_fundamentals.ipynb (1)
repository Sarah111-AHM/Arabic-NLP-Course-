      "source": [
        "## 2. Creating Tensors with Gradient Tracking\n",
        "\n",
        "`requires_grad=True` tells PyTorch to track operations for automatic differentiation."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "BRRT4JieUuLk",
        "outputId": "92f79efb-fdd8-4540-c572-dab2dbd28194"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "x = 0.5\n",
            "y = 100.0\n",
            "w = 50.0 (requires_grad=True)\n",
            "b = 0.0 (requires_grad=False)\n"
          ]
        }
      ],
      "source": [
        "import torch\n",
        "\n",
        "# Input data\n",
        "x = torch.tensor([[0.5]])\n",
        "y = torch.tensor([[100.0]])\n",
        "\n",
        "# Parameters - w needs gradients, b is fixed\n",
        "w = torch.tensor([[50.0]], requires_grad=True)\n",
        "b = torch.tensor([[0.0]], requires_grad=False)\n",
        "\n",
        "print(f\"x = {x.item()}\")\n",
        "print(f\"y = {y.item()}\")\n",
        "print(f\"w = {w.item()} (requires_grad={w.requires_grad})\")\n",
        "print(f\"b = {b.item()} (requires_grad={b.requires_grad})\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "aY7XONXZUuLl"
      },
      "source": [
        "## 3. Forward Pass"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "YZQxqwcOUuLl",
        "outputId": "8d99385e-6b2a-4fad-8564-8f887ebbf394"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Prediction: y_pred = 25.00\n",
            "Target:     y      = 100.00\n",
            "Loss (MSE):        = 5625.00\n"
          ]
        }
      ],
      "source": [
        "import torch\n",
        "\n",
        "# Setup\n",
        "x = torch.tensor([[0.5]])\n",
        "y = torch.tensor([[100.0]])\n",
        "w = torch.tensor([[50.0]], requires_grad=True)\n",
        "b = torch.tensor([[0.0]], requires_grad=False)\n",
        "\n",
        "# Forward pass: matrix multiplication + bias\n",
        "y_pred = x @ w + b  # @ is matrix multiplication (same as torch.matmul)\n",
        "loss = ((y_pred - y) ** 2).mean()\n",
        "\n",
        "print(f\"Prediction: y_pred = {y_pred.item():.2f}\")\n",
        "print(f\"Target:     y      = {y.item():.2f}\")\n",
        "print(f\"Loss (MSE):        = {loss.item():.2f}\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "ZUJoQTmeUuLl"
      },
      "source": [
        "## 4. Backward Pass\n",
        "\n",
        "`.backward()` computes ALL gradients automatically via chain rule."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "6aebfogMUuLl",
        "outputId": "22914dad-af40-46f4-8c6c-0e12adb2395c"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Gradient w.r.t. w: tensor([[-75.]])\n",
            "Gradient w.r.t. b: tensor([[-150.]])\n"
          ]
        }
      ],
      "source": [
        "import torch\n",
        "\n",
        "# Setup\n",
        "x = torch.tensor([[0.5]])\n",
        "y = torch.tensor([[100.0]])\n",
        "w = torch.tensor([[50.0]], requires_grad=True)\n",
        "b = torch.tensor([[0.0]], requires_grad=True)\n",
        "\n",
        "# Forward pass\n",
        "y_pred = x @ w + b\n",
        "loss = ((y_pred - y) ** 2).mean()\n",
        "\n",
        "# Backward pass - ONE line!\n",
        "loss.backward()\n",
        "\n",
        "print(f\"Gradient w.r.t. w: {w.grad}\")  # dL/dw\n",
        "print(f\"Gradient w.r.t. b: {b.grad}\")  # None - requires_grad=False"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "WriCELT5UuLl"
      },
      "source": [
        "## 5. Understanding the Gradient\n",
        "\n",
        "Manual derivative: dL/dw = -2 * x * (y - (w*x + b))\n",
        "\n",
        "For x=0.5, y=100, w=50, b=0:\n",
        "dL/dw = -2 * 0.5 * (100 - 25) = -75"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "WLFxsQ_bUuLm",
        "outputId": "e59c4052-4f06-415b-947c-9ae5bcf5fbf2"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Manual gradient:  -75.00\n",
            "PyTorch gradient: -75.00\n",
            "Match: True\n"
          ]
        }
      ],
      "source": [
        "import torch\n",
        "\n",
        "# Verify gradient computation manually\n",
        "x = 0.5\n",
        "y = 100.0\n",
        "w = 50.0\n",
        "b = 0.0\n",
        "\n",
        "# Manual derivative: d/dw (y - (w*x + b))^2 = -2*x*(y - (w*x + b))\n",
        "manual_grad = -2 * x * (y - (w * x + b))\n",
        "\n",
        "# Using PyTorch\n",
        "x_t = torch.tensor([[x]])\n",
        "y_t = torch.tensor([[y]])\n",
        "w_t = torch.tensor([[w]], requires_grad=True)\n",
        "b_t = torch.tensor([[b]])\n",
        "\n",
        "y_pred = x_t @ w_t + b_t\n",
        "loss = ((y_pred - y_t) ** 2).mean()\n",
        "loss.backward()\n",
        "\n",
        "print(f\"Manual gradient:  {manual_grad:.2f}\")\n",
        "print(f\"PyTorch gradient: {w_t.grad.item():.2f}\")\n",
        "print(f\"Match: {abs(manual_grad - w_t.grad.item()) < 1e-6}\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "cRcw0oUmUuLm"
      },
      "source": [
        "## 6. Complete Gradient Descent Step\n",
        "\n",
        "The four steps of optimization:\n",
        "1. Forward pass\n",
        "2. Backward pass\n",
        "3. Update parameters\n",
        "4. Zero gradients"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "_LsPA0K-UuLm"
      },
      "outputs": [],
      "source": [
        "import torch\n",
        "\n",
        "# Setup\n",
        "x = torch.tensor([[0.5]])\n",
        "y = torch.tensor([[100.0]])\n",
        "w = torch.tensor([[50.0]], requires_grad=True)\n",
        "b = torch.tensor([[0.0]], requires_grad=True)\n",
        "\n",
        "lr = 0.1  # Learning rate (alpha)\n",
        "\n",
        "print(f\"Before: w = {w.item():.2f}, b = {b.item():.2f}\")\n",
        "\n",
        "# 1. Forward pass\n",
        "y_pred = x @ w + b\n",
        "loss = ((y_pred - y) ** 2).mean()\n",
        "\n",
        "# 2. Backward pass\n",
        "loss.backward()\n",
        "\n",
        "# 3. Update parameters (inside no_grad context)\n",
        "with torch.no_grad():\n",
        "    w -= lr * w.grad\n",
        "    b -= lr * b.grad\n",
        "\n",
        "    # 4. Zero gradients for next iteration\n",
        "    w.grad = None\n",
        "    b.grad = None\n",
        "\n",
        "print(f\"After:  w = {w.item():.2f}, b = {b.item():.2f}\")\n",
        "print(f\"Gradients cleared: w.grad = {w.grad}, b.grad = {b.grad}\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "VSLvYqPLUuLm"
      },
      "source": [
        "## 7. Full Training Loop"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "ApdjvjOhUuLm",
        "outputId": "4ee72467-bd18-421b-80eb-f39a6bfabf04"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Trained parameters:\n",
            "  w = 200.00\n",
            "  b = 0.00\n",
            "\n",
            "Final prediction: y_pred = 100.00\n",
            "True target:     y      = 100.00\n"
          ]
        }
      ],
      "source": [
        "import torch\n",
        "\n",
        "# Setup data\n",
        "x = torch.tensor([[0.5]])\n",
        "y = torch.tensor([[100.0]])\n",
        "\n",
        "# Initialize parameters\n",
        "w = torch.tensor([[50.0]], requires_grad=True)\n",
        "b = torch.tensor([[0.0]], requires_grad=False)\n",
        "\n",
        "# Training loop\n",
        "for epoch in range(50000):\n",
        "    # Forward pass\n",
        "    y_pred = x @ w + b\n",
        "    loss = ((y_pred - y) ** 2).mean()\n",
        "\n",
        "    # Backward pass\n",
        "    loss.backward()\n",
        "\n",
        "    # Update with no_grad to avoid tracking the update itself\n",
        "    with torch.no_grad():\n",
        "        w -= 0.1 * w.grad\n",
        "        # b -= 0.1 * b.grad\n",
        "        w.grad = None\n",
        "        # b.grad = None\n",
        "\n",
        "print(f\"Trained parameters:\")\n",
        "print(f\"  w = {w.item():.2f}\")\n",
        "print(f\"  b = {b.item():.2f}\")\n",
        "print(f\"\\nFinal prediction: y_pred = {(x @ w + b).item():.2f}\")\n",
        "print(f\"True target:     y      = {y.item():.2f}\")"
      ]
    },
