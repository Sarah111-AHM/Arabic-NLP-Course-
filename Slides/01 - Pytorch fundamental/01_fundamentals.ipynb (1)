      "outputs": [],
      "source": [
        "import torch\n",
        "import torch.nn.functional as F\n",
        "from torch import nn\n",
        "\n",
        "y_pred = torch.tensor([2.5, 0.3, 1.8])\n",
        "y_true = torch.tensor([3.0, -0.5, 2.0])\n",
        "\n",
        "loss1 = ((y_pred - y_true) ** 2).mean()\n",
        "loss2 = F.mse_loss(y_pred, y_true)\n",
        "loss3 = nn.MSELoss()(y_pred, y_true)\n",
        "\n",
        "print(\"MSE Loss (all equivalent):\")\n",
        "print(f\"  Manual:    {loss1:.6f}\")\n",
        "print(f\"  F.mse_loss:   {loss2:.6f}\")\n",
        "print(f\"  nn.MSELoss:   {loss3:.6f}\")"
      ]
