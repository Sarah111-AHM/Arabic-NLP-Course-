      "source": [
        "## 9. Custom Model with `nn.Module`\n",
        "\n",
        "`nn.Module` is the base class for all neural network modules."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "gBxOMsygUuLn",
        "outputId": "b048d530-87c3-41aa-bfbf-0dc9a4b6ebef"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "LinearModel output: 0.9678\n",
            "FFN output:         -0.2771\n"
          ]
        }
      ],
      "source": [
        "import torch\n",
        "from torch import nn\n",
        "\n",
        "# Alternative: Feed-Forward Network with two layers\n",
        "class FFN(nn.Module):\n",
        "    def __init__(self):\n",
        "        super().__init__()\n",
        "        self.linear1 = nn.Linear(1, 1)\n",
        "        self.linear2 = nn.Linear(1, 1)\n",
        "\n",
        "    def forward(self, x):\n",
        "        x = self.linear1(x)\n",
        "        x = self.linear2(x)\n",
        "        return x\n",
        "\n",
        "# Create and use models\n",
        "model1 = nn.Linear(1, 1)\n",
        "model2 = FFN()\n",
        "\n",
        "x = torch.tensor([[0.5]])\n",
        "print(f\"LinearModel output: {model1(x).item():.4f}\")\n",
        "print(f\"FFN output:         {model2(x).item():.4f}\")"
      ]
    },
