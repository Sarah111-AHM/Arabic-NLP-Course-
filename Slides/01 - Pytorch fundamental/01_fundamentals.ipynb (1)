      "source": [
        "## 10. `nn.ModuleList` - Storing Multiple Layers\n",
        "\n",
        "Use `ModuleList` instead of plain Python lists so PyTorch registers the parameters."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "nC1CnsoiUuLn"
      },
      "outputs": [],
      "source": [
        "import torch\n",
        "import torch.nn as nn\n",
        "\n",
        "class MyModel(nn.Module):\n",
        "    def __init__(self, num_layers=3):\n",
        "        super().__init__()\n",
        "        self.layers = nn.ModuleList([\n",
        "            nn.Linear(1, 1) for _ in range(num_layers)\n",
        "        ])\n",
        "\n",
        "    def forward(self, x):\n",
        "        for layer in self.layers:\n",
        "            x = layer(x)\n",
        "        return x\n",
        "\n",
        "# Create model and check parameters are registered\n",
        "model = MyModel(num_layers=3)\n",
        "print(\"Model parameters:\")\n",
        "for name, param in model.named_parameters():\n",
        "    print(f\"  {name}: {param.shape}\")\n",
        "\n",
        "print(f\"\\nTotal parameters: {sum(p.numel() for p in model.parameters())}\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "UPXGT7LIUuLn"
      },
      "source": [
        "## 11. `nn.Parameter` - Registering Custom Tensors\n",
        "\n",
        "Wrap tensors in `nn.Parameter` so they're tracked by the module."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "CzcgN3KrUuLn"
      },
      "outputs": [],
      "source": [
        "import torch\n",
        "import torch.nn as nn\n",
        "\n",
        "class MyModel(nn.Module):\n",
        "    def __init__(self):\n",
        "        super().__init__()\n",
        "        self.W = nn.Parameter(torch.randn(1, 1))\n",
        "        self.b = nn.Parameter(torch.zeros(1, 1))\n",
        "\n",
        "    def forward(self, x):\n",
        "        return x @ self.W + self.b\n",
        "\n",
        "model = MyModel()\n",
        "print(\"Custom parameters:\")\n",
        "for name, param in model.named_parameters():\n",
        "    print(f\"  {name}: {param.item():.4f} (requires_grad={param.requires_grad})\")\n",
        "\n",
        "x = torch.tensor([[0.5]])\n",
        "y_pred = model(x)\n",
        "print(f\"\\nOutput: {y_pred.item():.4f}\")"
      ]
    },
